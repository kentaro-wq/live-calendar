# Supabase（https://supabase.com でプロジェクト作成後に取得）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend（https://resend.com でAPIキー取得）
RESEND_API_KEY=
