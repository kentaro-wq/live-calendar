# Supabase（https://supabase.com でプロジェクト作成後に取得）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend（https://resend.com でAPIキー取得）
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cron Job認証用シークレット（任意のランダムな文字列）
CRON_SECRET=

# 管理画面・管理API用シークレット（推測されにくい長い文字列）
ADMIN_SECRET=

# 配信停止リンクの署名用シークレット（ADMIN_SECRETとは別値推奨）
UNSUBSCRIBE_SECRET=

# アプリのURL（Vercelデプロイ後はVercelのURLに変更）
NEXT_PUBLIC_APP_URL=http://localhost:3000
